const db = require("../../../db");
const { quoteIdent } = require("../../../lib/utils");
const { emitProjectEvent } = require("../../../lib/realtime");
module.exports = async function (fastify) {
  fastify.delete("/:projectId/records/:id", async (req, reply) => {
    const { projectId, id } = req.params;

    const projectRes = await db.query(
      `SELECT schema_name FROM projects WHERE id = $1 LIMIT 1`,
      [projectId]
    );

    const project = projectRes.rows[0];
    if (!project) {
      return reply.code(404).send({ error: "Project not found" });
    }

    const schema = quoteIdent(project.schema_name);

    await db.query(
      `DELETE FROM ${schema}._records WHERE id = $1`,
      [id]
    );

    return { ok: true };
  });
};
